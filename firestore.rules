rules_version = '2';

// FinCheck Firestore security rules.
//
// This is a single-user personal finance app. Every document requires an
// authenticated (Google) user — the database is NEVER open to the public.
// Collections are currently flat (not partitioned per uid); if the app is
// ever opened to multiple users, scope each collection under
// /users/{uid}/... and compare request.auth.uid == uid instead.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
